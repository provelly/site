# ───────────────────────────────────────────────
#  CertAuth System - 환경변수 설정
#  이 파일을 .env 로 저장하고 값을 채워주세요
# ───────────────────────────────────────────────

PORT=3000

# 세션 시크릿 (임의의 긴 문자열로 변경 권장)
SESSION_SECRET=cert-auth-super-secret-2024

# ── Google OAuth ────────────────────────────────
# https://console.cloud.google.com 에서 발급
GOOGLE_CLIENT_ID=여기에_구글_클라이언트_ID
GOOGLE_CLIENT_SECRET=여기에_구글_클라이언트_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── Naver OAuth ─────────────────────────────────
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=여기에_네이버_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_네이버_클라이언트_SECRET
NAVER_CALLBACK_URL=http://localhost:3000/api/auth/naver/callback
