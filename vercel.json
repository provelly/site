{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/models/(.*)",
      "headers": { "Content-Type": "application/octet-stream" },
      "dest": "/public/models/$1"
    },
    {
      "src": "/(.+\\.wasm)",
      "headers": { "Content-Type": "application/wasm" },
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/face-api\\.min\\.js",
      "dest": "/public/face-api.min.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
